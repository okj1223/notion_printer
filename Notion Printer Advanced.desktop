[Desktop Entry]
Type=Application
Version=1.0
Name=Notion Printer Advanced
Comment=Open the advanced Notion Printer options
Exec=sh -c 'SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"; "$SCRIPT_DIR/notion_print_export_launcher.sh" --advanced "${1:-}"' %k %f
Terminal=false
Categories=Utility;
Icon=printer
StartupNotify=true
