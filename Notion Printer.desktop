[Desktop Entry]
Type=Application
Version=1.0
Name=Notion Printer
Comment=Generate print-friendly HTML from a Notion export
Exec=sh -c 'SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"; "$SCRIPT_DIR/notion_print_export_launcher.sh" "${1:-}"' %k %f
Terminal=false
MimeType=text/html;
Categories=Utility;
Icon=printer
StartupNotify=true
